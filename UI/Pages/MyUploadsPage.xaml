<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GregModmanager.MyUploadsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:GregModmanager.Models"
    xmlns:l="clr-namespace:GregModmanager.Localization"
    Title="{l:Translate Key=Tab_MyUploads}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="24" RowSpacing="16">

        <!--  Header  -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Style="{DynamicResource Headline}" Text="{l:Translate Key=Uploads_Headline}" />
            <Label Style="{DynamicResource SubHeadline}" Text="{l:Translate Key=Uploads_Subtitle}" />
            <Button Clicked="OnRefresh" Style="{DynamicResource SecondaryButton}" Text="{l:Translate Key=Uploads_RefreshList}" HorizontalOptions="Start" />
        </VerticalStackLayout>

        <!--  Selection bar  -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="12" BackgroundColor="{DynamicResource SurfaceContainerLow}" Padding="12,8">
            <Button Grid.Column="0" Clicked="OnImportSelected" Text="{l:Translate Key=Uploads_ImportSelected}" />
            <Label
                Grid.Column="1"
                x:Name="SelectionCountLabel"
                FontSize="12"
                TextColor="{DynamicResource OnSurfaceDim}"
                Text="0 selected"
                VerticalOptions="Center" />
        </Grid>

        <!--  Upload list  -->
        <RefreshView Grid.Row="2" x:Name="UploadsRefresh" Refreshing="OnRefreshPull">
            <CollectionView
                x:Name="UploadsList"
                SelectionChanged="OnUploadsSelectionChanged"
                SelectionMode="Multiple">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkshopItemDetailVm">
                        <Border Padding="16" Margin="0,0,0,8" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                                    HeightRequest="56" WidthRequest="56" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Image Source="{Binding PreviewImageSource}" Aspect="AspectFill" />
                                </Border>
                                <Label
                                    Grid.Row="0" Grid.Column="1"
                                    FontAttributes="Bold" FontSize="14"
                                    TextColor="{DynamicResource OnSurface}"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding Title}" />
                                <Label
                                    Grid.Row="1" Grid.Column="1"
                                    FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}"
                                    Text="{Binding PublishedFileId, StringFormat='File id: {0}'}" />
                                <Label
                                    Grid.Row="2" Grid.Column="1"
                                    FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}"
                                    Text="{Binding Updated, StringFormat='Updated: {0:g}'}" />
                                <HorizontalStackLayout Grid.Row="3" Grid.Column="1" Spacing="12">
                                    <Label FontSize="10" TextColor="{DynamicResource Primary}" Text="{Binding NumSubscriptions, StringFormat='Subs: {0}'}" />
                                    <Label FontSize="10" TextColor="{DynamicResource Primary}" Text="{Binding VotesUp, StringFormat='+{0}'}" />
                                    <Label FontSize="10" TextColor="{DynamicResource StatusError}" Text="{Binding VotesDown, StringFormat='-{0}'}" />
                                    <Label FontSize="10" TextColor="{DynamicResource OnSurfaceVariant}" Text="{Binding Score, StringFormat='Score: {0:P0}'}" />
                                </HorizontalStackLayout>
                                <VerticalStackLayout Grid.Row="0" Grid.RowSpan="4" Grid.Column="2" Spacing="4" VerticalOptions="Center">
                                    <Button Padding="14,6" Clicked="OnDownloadClicked" Text="{l:Translate Key=Import}"
                                        Style="{DynamicResource SecondaryButton}" FontSize="11" />
                                    <Button Padding="14,6" Clicked="OnViewOnSteam" Text="{l:Translate Key=Uploads_Steam}"
                                        Style="{DynamicResource TertiaryButton}" FontSize="11" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!--  Pagination  -->
        <HorizontalStackLayout Grid.Row="3" Spacing="8" HorizontalOptions="Center">
            <Button x:Name="PrevBtn" Text="{l:Translate Key=Previous}" Style="{DynamicResource SecondaryButton}" Clicked="OnPrev" IsEnabled="False" />
            <Label x:Name="PageLabel" FontSize="12" TextColor="{DynamicResource OnSurfaceDim}" VerticalOptions="Center" />
            <Button x:Name="NextBtn" Text="{l:Translate Key=Next}" Style="{DynamicResource SecondaryButton}" Clicked="OnNext" IsEnabled="False" />
        </HorizontalStackLayout>
    </Grid>

</ContentPage>



