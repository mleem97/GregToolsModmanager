<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GregModmanager.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:GregModmanager.Localization"
    Title="{l:Translate Key=Tab_Settings}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <VerticalStackLayout Spacing="6">
                <Label Style="{DynamicResource Headline}" Text="{l:Translate Key=Settings_Headline}" />
                <Label Style="{DynamicResource SubHeadline}" Text="{l:Translate Key=Settings_Subtitle}" />
            </VerticalStackLayout>

            <!--  Mod Store toggle  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Settings_ModStore}" />
                    <Label FontSize="12" TextColor="{DynamicResource OnSurfaceDim}" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Settings_ModStoreDesc}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" FontSize="13" TextColor="{DynamicResource OnSurface}" VerticalOptions="Center"
                            Text="{l:Translate Key=Settings_EnableModStore}" />
                        <Switch x:Name="ModStoreSwitch" Grid.Column="1"
                            OnColor="{DynamicResource Primary}" ThumbColor="{DynamicResource OnSurface}"
                            Toggled="OnModStoreToggled" />
                    </Grid>
                    <HorizontalStackLayout Spacing="8">
                        <Label x:Name="ModStoreHint" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" VerticalOptions="Center"
                            Text="{l:Translate Key=Settings_RestartRequired}" />
                        <Button x:Name="ModStoreRestartBtn" Text="{l:Translate Key=Settings_RestartNow}"
                            Clicked="OnRestartApp" Style="{DynamicResource TertiaryButton}" IsVisible="False" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  Game Root path (for Workshop sync to GameRoot/Mods/)  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Settings_GameRoot}" />
                    <Label FontSize="12" TextColor="{DynamicResource OnSurfaceDim}" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Settings_GameRootDesc}" />
                    <Label x:Name="CurrentGameRootLabel" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" LineBreakMode="WordWrap" />
                    <Entry x:Name="GameRootEntry" Placeholder="{l:Translate Key=Settings_GameRootPlaceholder}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="{l:Translate Key=Settings_Browse}" Clicked="OnBrowseGameRoot" Style="{DynamicResource SecondaryButton}" />
                        <Button Text="{l:Translate Key=Settings_Apply}" Clicked="OnApplyGameRoot" />
                        <Button Text="{l:Translate Key=Settings_ResetDefault}" Clicked="OnResetGameRoot" Style="{DynamicResource TertiaryButton}" />
                    </HorizontalStackLayout>
                    <Label x:Name="GameRootHint" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" />
                </VerticalStackLayout>
            </Border>

            <!--  Workspace path  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Settings_Workspace}" />
                    <Label FontSize="12" TextColor="{DynamicResource OnSurfaceDim}" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Settings_WorkspaceDesc}" />
                    <Label x:Name="CurrentPathLabel" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" LineBreakMode="WordWrap" />
                    <Entry x:Name="CustomPathEntry" Placeholder="{l:Translate Key=Settings_CustomPath}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="{l:Translate Key=Settings_Browse}" Clicked="OnBrowseFolder" Style="{DynamicResource SecondaryButton}" />
                        <Button Text="{l:Translate Key=Settings_Apply}" Clicked="OnApplyPath" />
                        <Button Text="{l:Translate Key=Settings_ResetDefault}" Clicked="OnResetPath" Style="{DynamicResource TertiaryButton}" />
                    </HorizontalStackLayout>
                    <Label x:Name="PathHint" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" />
                </VerticalStackLayout>
            </Border>

            <!--  Language  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Settings_Language}" />
                    <Label FontSize="12" TextColor="{DynamicResource OnSurfaceDim}" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Settings_LanguageDesc}" />
                    <Picker x:Name="LanguagePicker" SelectedIndexChanged="OnLanguageChanged" />
                    <HorizontalStackLayout Spacing="8">
                        <Label x:Name="LanguageHint" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" VerticalOptions="Center"
                            Text="{l:Translate Key=Settings_LanguageRestart}" />
                        <Button x:Name="LanguageRestartBtn" Text="{l:Translate Key=Settings_RestartNow}"
                            Clicked="OnRestartApp" Style="{DynamicResource TertiaryButton}" IsVisible="False" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  Logs  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Settings_Logs}" />
                    <Button Text="{l:Translate Key=Settings_OpenLogs}" Clicked="OnOpenLogs" Style="{DynamicResource SecondaryButton}" HorizontalOptions="Start" />
                    <Button Text="{l:Translate Key=Settings_CreateReproBundle}" Clicked="OnCreateReproBundle" Style="{DynamicResource SecondaryButton}" HorizontalOptions="Start" />
                </VerticalStackLayout>
            </Border>

            <!--  Community links  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Settings_Community}" />
                    <Button Text="{l:Translate Key=Settings_Discord}" Clicked="OnOpenDiscord" Style="{DynamicResource SecondaryButton}" HorizontalOptions="Start" />
                    <Button Text="{l:Translate Key=Settings_ModdingChannel}" Clicked="OnOpenModdingChannel" Style="{DynamicResource SecondaryButton}" HorizontalOptions="Start" />
                    <Button Text="{l:Translate Key=Settings_Website}" Clicked="OnOpenWebsite" Style="{DynamicResource SecondaryButton}" HorizontalOptions="Start" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>



