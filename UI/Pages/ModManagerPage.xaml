<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GregModmanager.ModManagerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:GregModmanager.Models"
    xmlns:l="clr-namespace:GregModmanager.Localization"
    Title="{l:Translate Key=Mod_Headline}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Luminescent Gradients -->
            <LinearGradientBrush x:Key="SignatureGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#61F4D8" Offset="0.0" />
                <GradientStop Color="#08C1A6" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*" BackgroundColor="{StaticResource Surface}">

        <!-- 1. EDITORIAL HEADER -->
        <Grid Grid.Row="0" Padding="32,40,32,24" ColumnDefinitions="*,Auto" BackgroundColor="{StaticResource SurfaceContainerLow}">
            <VerticalStackLayout Grid.Column="0" Spacing="8">
                <Label Text="ECOSYSTEM OVERVIEW" 
                       TextColor="{StaticResource Primary}" 
                       FontSize="10" 
                       FontFamily="SpaceGrotesk-Bold" 
                       CharacterSpacing="2.5" />
                <Label Style="{StaticResource Headline}" 
                       Text="{l:Translate Key=Mod_Headline}" 
                       FontSize="32" />
                <Label Text="{l:Translate Key=Mod_Subtitle}" 
                       TextColor="{StaticResource OnSurfaceVariant}" 
                       FontSize="14" 
                       FontFamily="Inter-Regular" />
            </VerticalStackLayout>
            
            <Button Grid.Column="1"
                    Clicked="OnRefreshCurrentTab"
                    Background="{StaticResource SignatureGradient}"
                    TextColor="{StaticResource OnPrimary}"
                    FontFamily="SpaceGrotesk-Bold"
                    Text="REFRESH CORE"
                    HeightRequest="48"
                    Padding="24,0"
                    VerticalOptions="Center" />
        </Grid>

        <!-- 2. STATUS BAR (Glassmorphism inspired) -->
        <Border x:Name="SyncStatusBar"
                Grid.Row="1"
                Padding="20,12"
                Margin="32,16,32,0"
                BackgroundColor="{StaticResource GlassBackground}"
                StrokeThickness="0"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Ellipse WidthRequest="10" HeightRequest="10" Fill="{StaticResource Primary}" />
                <Label x:Name="SyncStatusLabel"
                       FontFamily="JetBrainsMono-Regular"
                       FontSize="12"
                       TextColor="{StaticResource OnSurface}" />
            </HorizontalStackLayout>
        </Border>

        <!-- 3. NAVIGATION TABS (Structural Fixed Points) -->
        <Grid Grid.Row="2" Padding="32,24,32,16" ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
            <Button x:Name="TabStore" Grid.Column="0" Text="STORE" Clicked="OnTabStore" />
            <Button x:Name="TabInstalled" Grid.Column="1" Text="INSTALLED" Style="{StaticResource SecondaryButton}" Clicked="OnTabInstalled" />
            <Button x:Name="TabFavorites" Grid.Column="2" Text="FAVORITES" Style="{StaticResource SecondaryButton}" Clicked="OnTabFavorites" />
            <Button x:Name="TabHealth" Grid.Column="3" Text="DIAGNOSTICS" Style="{StaticResource SecondaryButton}" Clicked="OnTabHealth" />
        </Grid>

        <!-- 4. CONTENT AREA (Editorial Bleed) -->
        <Grid Grid.Row="3" Padding="32,0,32,32">

            <!-- STORE TAB -->
            <Grid x:Name="StoreView" RowDefinitions="Auto,*" RowSpacing="24">
                
                <Border Grid.Row="0" Padding="16,4" BackgroundColor="{StaticResource SurfaceContainer}" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry x:Name="SearchEntry" Placeholder="Query Archive..." 
                               TextColor="{StaticResource OnSurface}"
                               PlaceholderColor="{StaticResource OnSurfaceVariant}"
                               FontFamily="Inter-Regular"
                               BackgroundColor="Transparent" />
                        <Button Grid.Column="1" Text="SEARCH" Background="Transparent" TextColor="{StaticResource Primary}" Clicked="OnSearchSubmit" />
                    </Grid>
                </Border>

                <CollectionView Grid.Row="1" x:Name="StoreList" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="24" VerticalItemSpacing="24" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkshopItemDetailVm">
                            <Border BackgroundColor="{StaticResource SurfaceContainer}" StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Grid RowDefinitions="160, *">
                                    <Image Grid.Row="0" Source="{Binding PreviewImageSource}" Aspect="AspectFill" />
                                    <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="8">
                                        <Label Text="{Binding Title}" Style="{StaticResource SectionTitle}" FontSize="18" />
                                        <Label Text="{Binding OwnerName}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="12" />
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                                            <HorizontalStackLayout Grid.Column="0" Spacing="12">
                                                <Label Text="{Binding NumSubscriptions, StringFormat='{0} SUBS'}" FontSize="10" FontFamily="JetBrainsMono-Bold" TextColor="{StaticResource Tertiary}" />
                                            </HorizontalStackLayout>
                                            <Button Grid.Column="1" Text="ACQUIRE" Clicked="OnQuickSubscribe" Scale="0.9" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Other tabs follow same pattern -->
        </Grid>
    </Grid>
</ContentPage>
