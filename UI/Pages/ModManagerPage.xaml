<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GregModmanager.ModManagerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:GregModmanager.Models"
    xmlns:l="clr-namespace:GregModmanager.Localization"
    Title="{l:Translate Key=Mod_Headline}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <LinearGradientBrush x:Key="SignatureGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#61F4D8" Offset="0.0" />
                <GradientStop Color="#08C1A6" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*" BackgroundColor="{StaticResource Surface}">

        <!-- 1. HEADER -->
        <Grid Grid.Row="0" Padding="32,40,32,24" ColumnDefinitions="*,Auto" BackgroundColor="{StaticResource SurfaceContainerLow}">
            <VerticalStackLayout Grid.Column="0" Spacing="8">
                <Label Text="ECOSYSTEM OVERVIEW" TextColor="{StaticResource Primary}" FontSize="10" FontFamily="SpaceGrotesk-Bold" CharacterSpacing="2.5" />
                <Label Style="{StaticResource Headline}" Text="{l:Translate Key=Mod_Headline}" FontSize="32" />
                <Label Text="{l:Translate Key=Mod_Subtitle}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="14" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Clicked="OnRefreshCurrentTab" Background="{StaticResource SignatureGradient}" Text="REFRESH CORE" HeightRequest="48" Padding="24,0" VerticalOptions="Center" />
        </Grid>

        <!-- 2. STATUS BAR -->
        <Border x:Name="SyncStatusBar" Grid.Row="1" Padding="20,12" Margin="32,16,32,0" BackgroundColor="{StaticResource GlassBackground}" StrokeThickness="0" IsVisible="False">
            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Ellipse WidthRequest="10" HeightRequest="10" Fill="{StaticResource Primary}" />
                <Label x:Name="SyncStatusLabel" FontFamily="JetBrainsMono-Regular" FontSize="12" TextColor="{StaticResource OnSurface}" />
            </HorizontalStackLayout>
        </Border>

        <!-- 3. TABS -->
        <Grid Grid.Row="2" Padding="32,24,32,16" ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
            <Button x:Name="TabStore" Grid.Column="0" Text="STORE" Clicked="OnTabStore" />
            <Button x:Name="TabInstalled" Grid.Column="1" Text="INSTALLED" Style="{StaticResource SecondaryButton}" Clicked="OnTabInstalled" />
            <Button x:Name="TabFavorites" Grid.Column="2" Text="FAVORITES" Style="{StaticResource SecondaryButton}" Clicked="OnTabFavorites" />
            <Button x:Name="TabHealth" Grid.Column="3" Text="DIAGNOSTICS" Style="{StaticResource SecondaryButton}" Clicked="OnTabHealth" />
        </Grid>

        <!-- 4. CONTENT -->
        <Grid Grid.Row="3" Padding="32,0,32,32">
            
            <!-- STORE VIEW -->
            <Grid x:Name="StoreView" RowDefinitions="Auto,*,Auto" RowSpacing="20">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                    <Border Padding="12,0" BackgroundColor="{StaticResource SurfaceContainer}" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Entry x:Name="SearchEntry" Placeholder="Search mods..." BackgroundColor="Transparent" TextColor="{StaticResource OnSurface}" />
                    </Border>
                    <Picker x:Name="TagFilter" Grid.Column="1" Title="Tags" WidthRequest="150" BackgroundColor="{StaticResource SurfaceContainer}" />
                    <Picker x:Name="SortPicker" Grid.Column="2" Title="Sort" WidthRequest="150" BackgroundColor="{StaticResource SurfaceContainer}" />
                    <Button Grid.Column="3" Text="GO" Clicked="OnSearchSubmit" WidthRequest="60" />
                </Grid>

                <CollectionView Grid.Row="1" x:Name="StoreList" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="20" VerticalItemSpacing="20" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkshopItemDetailVm">
                            <Border BackgroundColor="{StaticResource SurfaceContainer}" StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <Grid RowDefinitions="140, *">
                                    <Image Source="{Binding PreviewImageSource}" Aspect="AspectFill" />
                                    <VerticalStackLayout Padding="16" Spacing="4">
                                        <Label Text="{Binding Title}" Style="{StaticResource SectionTitle}" MaxLines="1" />
                                        <Label Text="{Binding OwnerName}" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />
                                        <Button Text="DETAILS" Clicked="OnQuickSubscribe" Margin="0,8,0,0" HeightRequest="36" Padding="0" Scale="0.9" HorizontalOptions="End" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20" Padding="0,10">
                    <Button x:Name="StorePrevBtn" Text="&lt;" Clicked="OnStorePrev" IsEnabled="False" WidthRequest="44" />
                    <Label x:Name="StorePageLabel" Text="PAGE 1" VerticalOptions="Center" FontFamily="JetBrainsMono-Bold" />
                    <Button x:Name="StoreNextBtn" Text="&gt;" Clicked="OnStoreNext" IsEnabled="False" WidthRequest="44" />
                    <Label x:Name="StoreStatusLabel" TextColor="{StaticResource OnSurfaceVariant}" VerticalOptions="Center" Margin="20,0,0,0" />
                </HorizontalStackLayout>
            </Grid>

            <!-- INSTALLED VIEW -->
            <Grid x:Name="InstalledView" RowDefinitions="*,Auto" IsVisible="False">
                <CollectionView Grid.Row="0" x:Name="InstalledList" />
                <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="20">
                    <Button x:Name="InstalledPrevBtn" Text="&lt;" Clicked="OnInstalledPrev" />
                    <Label x:Name="InstalledPageLabel" Text="PAGE 1" VerticalOptions="Center" />
                    <Button x:Name="InstalledNextBtn" Text="&gt;" Clicked="OnInstalledNext" />
                    <Label x:Name="InstalledStatusLabel" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>

            <!-- FAVORITES VIEW -->
            <Grid x:Name="FavoritesView" RowDefinitions="*,Auto" IsVisible="False">
                <CollectionView Grid.Row="0" x:Name="FavoritesList" />
                <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="20">
                    <Button x:Name="FavoritesPrevBtn" Text="&lt;" Clicked="OnFavoritesPrev" />
                    <Label x:Name="FavoritesPageLabel" Text="PAGE 1" VerticalOptions="Center" />
                    <Button x:Name="FavoritesNextBtn" Text="&gt;" Clicked="OnFavoritesNext" />
                    <Label x:Name="FavoritesStatusLabel" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>

            <!-- HEALTH / DIAGNOSTICS VIEW -->
            <ScrollView x:Name="HealthView" IsVisible="False">
                <VerticalStackLayout Spacing="24">
                    <Border Padding="20" BackgroundColor="{StaticResource SurfaceContainer}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="MELONLOADER STATUS" Style="{StaticResource SectionTitle}" />
                            <Label x:Name="MelonStatusLabel" Text="Scanning environment..." />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="20" BackgroundColor="{StaticResource SurfaceContainer}">
                        <Border.StrokeShape><RoundRectangle CornerRectangle="12"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="16">
                            <Label Text="PLUGIN DISTRIBUTION CHANNELS" Style="{StaticResource SectionTitle}" />
                            <Picker x:Name="ChannelPicker" Title="Select active channel" />
                            <Label x:Name="ChannelInfoLabel" TextColor="{StaticResource OnSurfaceVariant}" />
                            <CollectionView x:Name="PluginsList" HeightRequest="200" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="20" BackgroundColor="{StaticResource SurfaceContainer}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="DEPENDENCY AUDIT" Style="{StaticResource SectionTitle}" />
                            <CollectionView x:Name="ChecksList" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>
