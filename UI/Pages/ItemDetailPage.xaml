<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GregModmanager.ItemDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:GregModmanager.Localization"
    Title="{l:Translate Key=Detail_ItemDetail}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!--  Loading  -->
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True" Color="{DynamicResource Primary}" />

            <!--  Content (hidden until loaded)  -->
            <VerticalStackLayout x:Name="ContentRoot" IsVisible="False" Spacing="20">

                <HorizontalStackLayout HorizontalOptions="End">
                    <Button
                        Clicked="OnRefreshDetail"
                        Style="{DynamicResource SecondaryButton}"
                        Text="{l:Translate Key=Refresh}" />
                </HorizontalStackLayout>

                <!--  Header: large preview + title  -->
                <Grid ColumnDefinitions="160,*" ColumnSpacing="20">
                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                        HeightRequest="160" WidthRequest="160">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Image x:Name="PreviewImage" Aspect="AspectFill" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Label x:Name="ItemTitle" Style="{DynamicResource Headline}" LineBreakMode="WordWrap" />
                        <HorizontalStackLayout Spacing="8">
                            <Label x:Name="SourceBadge" FontSize="11" Padding="8,3" BackgroundColor="{DynamicResource SurfaceContainer}" />
                            <Label x:Name="AuthorLabel" FontSize="13" TextColor="{DynamicResource OnSurfaceDim}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label x:Name="VisibilityLabel" Style="{DynamicResource MetaBadge}" />
                        <Label x:Name="StatusLabel" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Grid>

                <!--  Two-column body: LEFT sidebar  |  RIGHT main content  -->
                <Grid ColumnDefinitions="280,*" ColumnSpacing="20">

                    <!--  LEFT SIDEBAR  -->
                    <VerticalStackLayout Grid.Column="0" Spacing="16">

                        <!--  Actions card  -->
                        <Border Padding="16" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainer}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Detail_Actions}" />
                                <Button x:Name="SubscribeBtn" Clicked="OnSubscribeToggle" Text="{l:Translate Key=Detail_Subscribe}" />
                                <Button x:Name="FavoriteBtn" Clicked="OnFavoriteToggle" Style="{DynamicResource SecondaryButton}" Text="{l:Translate Key=Detail_Favorite}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Button Grid.Column="0" x:Name="VoteUpBtn" Clicked="OnVoteUp" Style="{DynamicResource SecondaryButton}" Text="{l:Translate Key=Detail_VoteUp}" />
                                    <Button Grid.Column="1" x:Name="VoteDownBtn" Clicked="OnVoteDown" Style="{DynamicResource SecondaryButton}" Text="{l:Translate Key=Detail_VoteDown}" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{DynamicResource SurfaceVariant}" Margin="0,2" />
                                <Button Clicked="OnOpenInSteam" Style="{DynamicResource TertiaryButton}" Text="{l:Translate Key=Detail_OpenInSteam}" />
                                <Button Clicked="OnOpenChangelog" Style="{DynamicResource TertiaryButton}" Text="{l:Translate Key=Detail_Changelog}" />
                                <Button Clicked="OnOpenComments" Style="{DynamicResource TertiaryButton}" Text="{l:Translate Key=Detail_Comments}" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Taxonomies / Tags card  -->
                        <Border Padding="16" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Detail_Tags}" />
                                <FlexLayout x:Name="TagsLayout" Wrap="Wrap" JustifyContent="Start" Direction="Row" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Info / Metadata card  -->
                        <Border Padding="16" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Detail_Info}" />

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="12">
                                    <Label Grid.Row="0" Grid.Column="0" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" Text="{l:Translate Key=Detail_Created}" />
                                    <Label Grid.Row="0" Grid.Column="1" x:Name="CreatedLabel" FontSize="11" TextColor="{DynamicResource OnSurface}" />
                                    <Label Grid.Row="1" Grid.Column="0" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" Text="{l:Translate Key=Detail_Updated}" />
                                    <Label Grid.Row="1" Grid.Column="1" x:Name="UpdatedLabel" FontSize="11" TextColor="{DynamicResource OnSurface}" />
                                    <Label Grid.Row="2" Grid.Column="0" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" Text="{l:Translate Key=Detail_Size}" />
                                    <Label Grid.Row="2" Grid.Column="1" x:Name="SizeLabel" FontSize="11" TextColor="{DynamicResource OnSurface}" />
                                    <Label Grid.Row="3" Grid.Column="0" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" Text="{l:Translate Key=Detail_Visibility}" />
                                    <Label Grid.Row="3" Grid.Column="1" x:Name="VisibilitySidebarLabel" FontSize="11" TextColor="{DynamicResource OnSurface}" />
                                    <Label Grid.Row="4" Grid.Column="0" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" Text="{l:Translate Key=Detail_FileId}" />
                                    <Label Grid.Row="4" Grid.Column="1" x:Name="FileIdLabel" FontSize="11" TextColor="{DynamicResource OnSurface}" />
                                    <Label Grid.Row="5" Grid.Column="0" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" Text="{l:Translate Key=Detail_Score}" />
                                    <Label Grid.Row="5" Grid.Column="1" x:Name="ScoreLabel" FontSize="11" TextColor="{DynamicResource OnSurface}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                    <!--  RIGHT MAIN COLUMN  -->
                    <VerticalStackLayout Grid.Column="1" Spacing="16">

                        <!--  Stats row  -->
                        <Border Padding="16" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                    <Label x:Name="SubsCount" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Primary}" HorizontalTextAlignment="Center" />
                                    <Label Text="{l:Translate Key=Detail_Subscriptions}" FontSize="10" TextColor="{DynamicResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                    <Label x:Name="FavsCount" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Primary}" HorizontalTextAlignment="Center" />
                                    <Label Text="{l:Translate Key=Detail_Favorites}" FontSize="10" TextColor="{DynamicResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                    <Label x:Name="VotesLabel" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Primary}" HorizontalTextAlignment="Center" />
                                    <Label Text="{l:Translate Key=Detail_Votes}" FontSize="10" TextColor="{DynamicResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                                    <Label x:Name="CommentsCount" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Primary}" HorizontalTextAlignment="Center" />
                                    <Label Text="{l:Translate Key=Detail_Comments}" FontSize="10" TextColor="{DynamicResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!--  Inferred dependencies (tags + description)  -->
                        <Border x:Name="DependencyCard" Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainer}" IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{DynamicResource SectionTitle}" TextColor="{DynamicResource WarningAccent}" Text="{l:Translate Key=Detail_DependenciesHeading}" />
                                <Label x:Name="DependenciesBodyLabel" FontSize="13" TextColor="{DynamicResource WarningAccentDim}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Description card  -->
                        <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Detail_Description}" />
                                <Label x:Name="DescriptionLabel" FontSize="13" TextColor="{DynamicResource OnSurface}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Gallery (additional preview images) card  -->
                        <Border x:Name="GalleryCard" Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}" IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Detail_Gallery}" />
                                <FlexLayout x:Name="GalleryLayout" Wrap="Wrap" JustifyContent="Start" Direction="Row" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Versions / Changelog card  -->
                        <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0" Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Detail_Versions}" VerticalOptions="Center" />
                                    <Button Grid.Column="1" Clicked="OnOpenChangelog" Style="{DynamicResource TertiaryButton}" Text="{l:Translate Key=Detail_ViewFullChangelog}" />
                                </Grid>
                                <Label x:Name="VersionInfoLabel" FontSize="12" TextColor="{DynamicResource OnSurfaceDim}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Comments summary card  -->
                        <Border Padding="20" StrokeThickness="0" BackgroundColor="{DynamicResource SurfaceContainerLow}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0" Style="{DynamicResource SectionTitle}" Text="{l:Translate Key=Detail_Comments}" VerticalOptions="Center" />
                                    <Button Grid.Column="1" Clicked="OnOpenComments" Style="{DynamicResource TertiaryButton}" Text="{l:Translate Key=Detail_ViewAllComments}" />
                                </Grid>
                                <Label x:Name="CommentsInfoLabel" FontSize="12" TextColor="{DynamicResource OnSurfaceDim}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>



