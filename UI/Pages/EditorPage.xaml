<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GregModmanager.EditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:GregModmanager.Models"
    xmlns:l="clr-namespace:GregModmanager.Localization"
    Title="Workshop item">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!--  Page header  -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Style="{StaticResource Headline}" Text="{l:Translate Key=Editor_Headline}" />
                    <Label x:Name="PathLabel" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                    <Button Clicked="OnReloadFromDisk" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=Refresh}" />
                    <Button Clicked="OnOpenInExplorer" Style="{StaticResource TertiaryButton}" Text="{l:Translate Key=Editor_Explorer}" />
                </HorizontalStackLayout>
            </Grid>

            <!--  Sub-tabs  -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button x:Name="TabBtnDetails" Grid.Column="0" Clicked="OnTabDetails" Text="{l:Translate Key=Editor_TabDetails}" />
                <Button x:Name="TabBtnAssets" Grid.Column="1" Clicked="OnTabAssets" Text="{l:Translate Key=Editor_TabAssets}" />
                <Button x:Name="TabBtnPublish" Grid.Column="2" Clicked="OnTabPublish" Text="{l:Translate Key=Editor_TabPublish}" />
            </Grid>

            <!--  TAB: Details (metadata + BB + greg)  -->
            <Border x:Name="PanelDetails" Padding="20" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceContainerLow}" IsVisible="True">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Editor_Metadata}" />

                    <Label Text="{l:Translate Key=Editor_Title}" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                    <Entry x:Name="TitleEntry" MaxLength="128" TextChanged="OnTitleChanged" />
                    <Label x:Name="TitleCountLabel" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />

                    <Label Text="{l:Translate Key=Editor_Description}" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                    <Border Padding="4,2" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceContainer}" Margin="0,0,0,2">
                        <Border.StrokeShape><RoundRectangle CornerRadius="6,6,0,0" /></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="2">
                            <Button Text="B" Clicked="OnBbBold" Style="{StaticResource BbButton}" FontAttributes="Bold" />
                            <Button Text="I" Clicked="OnBbItalic" Style="{StaticResource BbButton}" FontAttributes="Italic" />
                            <Button Text="U" Clicked="OnBbUnderline" Style="{StaticResource BbButton}" />
                            <Button Text="S" Clicked="OnBbStrike" Style="{StaticResource BbButton}" />
                            <BoxView WidthRequest="1" Color="{StaticResource SurfaceVariant}" Margin="2,4" />
                            <Button Text="H1" Clicked="OnBbH1" Style="{StaticResource BbButton}" />
                            <Button Text="H2" Clicked="OnBbH2" Style="{StaticResource BbButton}" />
                            <Button Text="H3" Clicked="OnBbH3" Style="{StaticResource BbButton}" />
                            <BoxView WidthRequest="1" Color="{StaticResource SurfaceVariant}" Margin="2,4" />
                            <Button Text="URL" Clicked="OnBbUrl" Style="{StaticResource BbButton}" />
                            <Button Text="IMG" Clicked="OnBbImg" Style="{StaticResource BbButton}" />
                            <BoxView WidthRequest="1" Color="{StaticResource SurfaceVariant}" Margin="2,4" />
                            <Button Text="List" Clicked="OnBbList" Style="{StaticResource BbButton}" />
                            <Button Text="Code" Clicked="OnBbCode" Style="{StaticResource BbButton}" />
                            <Button Text="Quote" Clicked="OnBbQuote" Style="{StaticResource BbButton}" />
                            <Button Text="—" Clicked="OnBbHr" Style="{StaticResource BbButton}" ToolTipProperties.Text="Horizontal rule" />
                            <Button Text="Spoiler" Clicked="OnBbSpoiler" Style="{StaticResource BbButton}" />
                            <BoxView WidthRequest="1" Color="{StaticResource SurfaceVariant}" Margin="2,4" />
                            <Button Text="Table" Clicked="OnBbTable" Style="{StaticResource BbButton}" />
                        </HorizontalStackLayout>
                    </Border>
                    <Editor x:Name="DescriptionEditor" AutoSize="TextChanges" HeightRequest="120" TextChanged="OnDescriptionChanged" />
                    <Label x:Name="DescriptionCountLabel" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />

                    <Label Margin="0,8,0,0" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}"
                        Text="{l:Translate Key=Editor_BbLivePreview}" />
                    <Border Padding="0" Margin="0,0,0,2" BackgroundColor="{StaticResource SurfaceContainer}" StrokeThickness="1" Stroke="{StaticResource SurfaceVariant}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                        <WebView x:Name="DescriptionBbPreview" HeightRequest="220" />
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{l:Translate Key=Editor_Visibility}" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                            <Picker x:Name="VisibilityPicker" Title="{l:Translate Key=Editor_Visibility}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="{l:Translate Key=Editor_Tags}" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                            <Entry x:Name="TagsEntry" Placeholder="{l:Translate Key=Editor_TagsPlaceholder}" TextChanged="OnTagsChanged" />
                            <Label x:Name="TagsHintLabel" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource SurfaceVariant}" Margin="0,4" />

                    <Label FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" Text="{l:Translate Key=Editor_NativeProfile}" />
                    <Label FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" Text="{l:Translate Key=Editor_NativeProfileHint}" />
                    <Picker x:Name="NativeProfilePicker" SelectedIndexChanged="OnNativeProfileChanged" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{l:Translate Key=Editor_NeedsMelonLoader}" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                            <Label FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" Text="{l:Translate Key=Editor_NeedsMelonLoaderHint}" />
                        </VerticalStackLayout>
                        <Switch x:Name="NeedsMelonLoaderSwitch" Grid.Column="1"
                            OnColor="{StaticResource Primary}" ThumbColor="{StaticResource OnSurface}"
                            Toggled="OnNeedsMelonLoaderToggled"
                            VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{l:Translate Key=Editor_Needsgreg}" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                            <Label FontSize="11" TextColor="{StaticResource OnSurfaceVariant}"
                                Text="{l:Translate Key=Editor_NeedsgregHint}" />
                        </VerticalStackLayout>
                        <Switch x:Name="NeedsgregSwitch" Grid.Column="1"
                            OnColor="{StaticResource Primary}" ThumbColor="{StaticResource OnSurface}"
                            Toggled="OnNeedsgregToggled"
                            VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource SurfaceVariant}" Margin="0,8" />

                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Editor_WorkshopDependencies}" />
                    <Label FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Editor_WorkshopDependenciesHint}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="WorkshopDepIdEntry" Grid.Column="0" Keyboard="Numeric"
                            Placeholder="{l:Translate Key=Editor_WorkshopDepIdPlaceholder}" />
                        <Button Grid.Column="1" Clicked="OnWorkshopDepAddById" Style="{StaticResource SecondaryButton}"
                            Text="{l:Translate Key=Editor_WorkshopDepAdd}" />
                    </Grid>
                    <VerticalStackLayout x:Name="WorkshopDepStack" Spacing="6" />

                    <Label FontSize="11" TextColor="{StaticResource OnSurfaceDim}" Text="{l:Translate Key=Editor_WorkshopDepSearchTitle}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="WorkshopDepSearchEntry" Grid.Column="0"
                            Placeholder="{l:Translate Key=Editor_WorkshopDepSearchPlaceholder}"
                            Completed="OnWorkshopDepSearchCompleted" />
                        <Button Grid.Column="1" Clicked="OnWorkshopDepSearch" Style="{StaticResource SecondaryButton}"
                            Text="{l:Translate Key=Search}" />
                    </Grid>
                    <CollectionView x:Name="WorkshopDepSearchList" HeightRequest="220" IsVisible="False"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WorkshopItemDetailVm">
                                <Border Padding="8" Margin="0,0,0,4" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceContainer}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnWorkshopDepSearchItemTapped" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="48,*" ColumnSpacing="8">
                                        <Border Grid.Column="0" HeightRequest="48" WidthRequest="48" StrokeThickness="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6" />
                                            </Border.StrokeShape>
                                            <Image Aspect="AspectFill" Source="{Binding PreviewImageSource}" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label FontAttributes="Bold" FontSize="13" LineBreakMode="TailTruncation"
                                                Text="{Binding Title}" TextColor="{StaticResource OnSurface}" />
                                            <Label FontSize="10" TextColor="{StaticResource OnSurfaceVariant}"
                                                Text="{Binding PublishedFileId, StringFormat='ID: {0}'}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!--  TAB: Assets (preview image, content, screenshots)  -->
            <Border x:Name="PanelAssets" Padding="20" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceContainerLow}" IsVisible="False">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Editor_PreviewContent}" />

                    <Label FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" Text="{l:Translate Key=Editor_PreviewHint}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Clicked="OnPickPreview" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=Editor_ChooseImage}" />
                        <Label x:Name="PreviewPathLabel" FontSize="11" TextColor="{StaticResource OnSurfaceDim}" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource SurfaceVariant}" Margin="0,4" />

                    <Label x:Name="ContentStatusLabel" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                    <Label x:Name="ContentSizeBody" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" LineBreakMode="WordWrap" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Clicked="OnExportContentZip" Style="{StaticResource TertiaryButton}" Text="{l:Translate Key=Editor_ExportZip}" />
                        <Button Clicked="OnOpenNativeConfigEditor" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=Editor_NativeConfigButton}" />
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource SurfaceVariant}" Margin="0,8" />

                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Editor_Screenshots}" />
                    <Label FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" Text="{l:Translate Key=Editor_ScreenshotsHint}" />
                    <FlexLayout x:Name="ScreenshotsGallery" Wrap="Wrap" JustifyContent="Start" Direction="Row" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Clicked="OnAddScreenshot" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=Editor_AddScreenshot}" />
                        <Label x:Name="ScreenshotCountLabel" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  TAB: Publish (changelog, readiness, Steam)  -->
            <VerticalStackLayout x:Name="PanelPublish" Spacing="16" IsVisible="False">

                <Border Padding="20" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceContainerLow}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Editor_ChangeNotes}" />
                        <Label x:Name="ChangeLogHintLabel" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}"
                            Text="{l:Translate Key=Editor_ChangeNotesHint}" />
                        <Editor x:Name="ChangeLogEditor" AutoSize="TextChanges" HeightRequest="80"
                            Placeholder="{l:Translate Key=Editor_ChangeNotesPlaceholder}"
                            TextChanged="OnChangeLogTextChanged" />
                    </VerticalStackLayout>
                </Border>

                <Border Padding="20" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceContainerLow}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Editor_UploadReadiness}" VerticalOptions="Center" />
                            <Button Grid.Column="1" x:Name="RecheckBtn" Clicked="OnRunUploadCheck" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=Editor_Recheck}" VerticalOptions="Center" />
                        </Grid>
                        <Label x:Name="ReadinessStatusLabel" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <CollectionView x:Name="CheckResultsList" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:UploadCheckResult">
                                    <Grid Padding="0,4" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Ellipse x:Name="CheckDot" Grid.Column="0" WidthRequest="10" HeightRequest="10" VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label FontAttributes="Bold" FontSize="12" TextColor="{StaticResource OnSurface}" Text="{Binding Label}" />
                                            <Label FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" LineBreakMode="WordWrap" Text="{Binding Detail}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Padding="20" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceContainer}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Editor_Publish}" />
                            <Label x:Name="PublishedIdLabel" FontSize="12" TextColor="{StaticResource OnSurfaceDim}" />
                            <Label x:Name="SyncStatusLabel" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <Button Clicked="OnSaveAndUpload" Text="{l:Translate Key=Editor_SaveUpload}" />
                            <HorizontalStackLayout Spacing="8">
                                <Button Clicked="OnSave" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=Editor_SaveMeta}" />
                                <Button x:Name="ViewOnSteamBtn" Clicked="OnViewOnSteam" Style="{StaticResource TertiaryButton}" Text="{l:Translate Key=Editor_ViewOnSteam}" IsVisible="False" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

