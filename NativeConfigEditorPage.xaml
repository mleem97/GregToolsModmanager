<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkshopUploader.NativeConfigEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:WorkshopUploader.Localization"
    Title="{l:Translate Key=NativeConfig_Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="12">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <Label
                Grid.Column="0"
                x:Name="HeaderPathLabel"
                FontSize="11"
                LineBreakMode="MiddleTruncation"
                TextColor="#7FBFB8"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Clicked="OnSave"
                Text="{l:Translate Key=NativeConfig_Save}" />
            <Button
                Grid.Column="2"
                Clicked="OnBack"
                Style="{StaticResource SecondaryButton}"
                Text="{l:Translate Key=NativeConfig_Back}" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
            <Button x:Name="TabNativeBtn" Clicked="OnTabNative" Text="{l:Translate Key=NativeConfig_TabNative}" />
            <Button x:Name="TabOptionsBtn" Clicked="OnTabOptions" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=NativeConfig_TabOptions}" />
        </Grid>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="14">

                <!--  config.json panel  -->
                <VerticalStackLayout x:Name="PanelNative" Spacing="12" IsVisible="True">

                    <Border x:Name="DecorationProfileHintBorder" Padding="14" BackgroundColor="#001E1C" StrokeThickness="0" IsVisible="False">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Label
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            Text="{l:Translate Key=NativeConfig_ProfileDecorationHint}"
                            TextColor="#7FBFB8" />
                    </Border>

                    <Border x:Name="Il2CppNoticeBorder" Padding="14" BackgroundColor="#001E1C" StrokeThickness="0" IsVisible="False">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Label
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            Text="{l:Translate Key=NativeConfig_Il2CppNotice}"
                            TextColor="#7FBFB8" />
                    </Border>

                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_ModName}" />
                    <Entry x:Name="ModNameEntry" MaxLength="256" />

                    <VerticalStackLayout x:Name="PanelShopDecoration" Spacing="12">
                        <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_ShopItems}" />
                        <VerticalStackLayout x:Name="ShopItemsStack" Spacing="10" />
                        <Button Clicked="OnAddShopItem" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=NativeConfig_AddShopItem}" HorizontalOptions="Start" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="PanelStaticDecoration" Spacing="12">
                        <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_StaticItems}" />
                        <VerticalStackLayout x:Name="StaticItemsStack" Spacing="10" />
                        <Button Clicked="OnAddStaticItem" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=NativeConfig_AddStaticItem}" HorizontalOptions="Start" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="PanelDllCode" Spacing="12">
                        <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_Dlls}" />
                        <VerticalStackLayout x:Name="DllsStack" Spacing="10" />
                        <Button Clicked="OnAddDll" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=NativeConfig_AddDll}" HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!--  modconfig.json panel  -->
                <VerticalStackLayout x:Name="PanelOptions" Spacing="12" IsVisible="False">

                    <Border Padding="14" BackgroundColor="#001E1C" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Label
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            Text="{l:Translate Key=NativeConfig_ModOptionsHint}"
                            TextColor="#7FBFB8" />
                    </Border>

                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_SchemaVersion}" />
                    <Entry x:Name="SchemaVersionEntry" Keyboard="Numeric" />

                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_ModKind}" />
                    <Picker x:Name="ModKindPicker">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>standalone</x:String>
                                <x:String>fmf</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_OptionsNotes}" />
                    <Editor x:Name="ModOptionsNotesEditor" AutoSize="TextChanges" HeightRequest="72" />

                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NativeConfig_Settings}" />
                    <VerticalStackLayout x:Name="SettingsStack" Spacing="8" />
                    <Button Clicked="OnAddSetting" Style="{StaticResource SecondaryButton}" Text="{l:Translate Key=NativeConfig_AddSetting}" HorizontalOptions="Start" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
