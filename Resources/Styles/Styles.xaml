<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  ═══════════════════════════════════════════════════
         The Luminescent Architect — Design System for MAUI
         Surface hierarchy via tonal depth, no explicit borders.
         ═══════════════════════════════════════════════════  -->

    <!--  Page: Layer 0 deep abyss  -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
    </Style>

    <!--  Shell: dark nav bar with teal accent  -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource OnSurface}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource SurfaceContainerLow}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource OnSurfaceVariant}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <!--  ── Typography ── -->

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontFamily" Value="Inter-Regular" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="Label" x:Key="Headline">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontFamily" Value="SpaceGrotesk-Bold" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="CharacterSpacing" Value="0.52" />
    </Style>

    <Style TargetType="Label" x:Key="SectionTitle">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontFamily" Value="SpaceGrotesk-Bold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CharacterSpacing" Value="0.3" />
    </Style>

    <Style TargetType="Label" x:Key="CodeLabel">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="JetBrainsMono-Regular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerHighest}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!--  ── Containers: tonal layering ── -->

    <Style TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainer}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainer}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
    </Style>

    <!--  ── Buttons: kinetic core ──  -->

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource OnPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="SpaceGrotesk-Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CharacterSpacing" Value="0.3" />
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderColor" Value="{StaticResource Outline}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontFamily" Value="SpaceGrotesk-Medium" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

</ResourceDictionary>
