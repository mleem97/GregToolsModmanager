<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- LUMINESCENT ARCHITECT COLOR PALETTE -->
    
    <!-- Primaries (Teal Kinetic Core) -->
    <Color x:Key="Primary">#61F4D8</Color>
    <Color x:Key="PrimaryContainer">#08C1A6</Color>
    <Color x:Key="OnPrimary">#001110</Color>
    
    <!-- Secondaries (Atmospheric Teal) -->
    <Color x:Key="Secondary">#1CEDE1</Color>
    <Color x:Key="SecondaryContainer">#003734</Color>
    <Color x:Key="OnSecondary">#C0FCF6</Color>

    <!-- Surfaces (The Deep Abyss) -->
    <Color x:Key="Surface">#001110</Color>
    <Color x:Key="SurfaceContainerLow">#001715</Color>
    <Color x:Key="SurfaceContainer">#001E1C</Color>
    <Color x:Key="SurfaceContainerHigh">#002422</Color>
    <Color x:Key="SurfaceContainerHighest">#002B29</Color>
    
    <!-- OnSurfaces (Softened for Eye Strain) -->
    <Color x:Key="OnSurface">#C0FCF6</Color>
    <Color x:Key="OnSurfaceVariant">#80B0AB</Color>
    
    <!-- Accents & Feedback -->
    <Color x:Key="Tertiary">#64D0FF</Color>
    <Color x:Key="Error">#D7383B</Color>
    <Color x:Key="Outline">#3F4F4D</Color>
    <Color x:Key="OutlineVariant">#1F2F2D</Color>

    <!-- Transparent / Glass Variants -->
    <Color x:Key="GlassBackground">#CC001E1C</Color> <!-- 80% Opacity -->
    <Color x:Key="PrimaryGlow">#1A61F4D8</Color> <!-- 10% Opacity -->

</ResourceDictionary>
