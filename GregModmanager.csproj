<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9.0-windows10.0.19041.0;net9.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>GregModmanager</RootNamespace>
    <UseMaui Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>GregModmanager</AssemblyName>
    <ApplicationTitle>gregModmanager</ApplicationTitle>
    <ApplicationId>eu.gregframework.modmanager</ApplicationId>
    <ApplicationDisplayVersion>1.0.0.30-pre</ApplicationDisplayVersion>
    <ApplicationVersion>4</ApplicationVersion>
    <Version>1.1.0</Version>
    <InformationalVersion>1.1.0</InformationalVersion>
    
    <WindowsPackageType Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">None</WindowsPackageType>
    <WindowsAppSDKSelfContained Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">true</WindowsAppSDKSelfContained>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifiers>win-x64;linux-x64</RuntimeIdentifiers>
    <SatelliteResourceLanguages>en;de;es;it;ja;pl;ru;zh</SatelliteResourceLanguages>
  </PropertyGroup>

  <!-- Windows Specific -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-windows10.0.19041.0'">
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net9.0'">
    <Compile Remove="Program.cs" />
  </ItemGroup>

  <!-- Linux / Headless Specific (Exclude ONLY UI and MAUI specific parts) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <Compile Remove="**\*.xaml.cs" />
    <Compile Remove="App.xaml.cs" />
    <Compile Remove="AppShell.xaml.cs" />
    <Compile Remove="MauiProgram.cs" />
    <Compile Remove="Platforms\**\*.cs" />
    <Compile Remove="Localization\TranslateExtension.cs" />
    <Compile Remove="Models\ProjectTileVm.cs" />
    <None Include="**\*.xaml" />
  </ItemGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseMaui)' == 'true'">
    <MauiIcon Include="Resources\AppIcon\appicon.svg" Color="#001110" />
    <MauiSplashScreen Include="Resources\Splash\splash.svg" Color="#001110" />
    <MauiFont Include="Resources\Fonts\Vendored\Inter\*.ttf" />
    <MauiFont Include="Resources\Fonts\Vendored\SpaceGrotesk\*.ttf" />
    <MauiFont Include="Resources\Fonts\Vendored\JetBrainsMono\*.ttf" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" Version="9.0.90" Condition="'$(UseMaui)' == 'true'" />
    <PackageReference Include="Facepunch.Steamworks" Version="2.3.3" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="GregModmanager.Tests\**\*.cs" />
    <Compile Remove="**\obj\**\*.cs" />
    <Compile Remove="**\bin\**\*.cs" />
  </ItemGroup>

</Project>
